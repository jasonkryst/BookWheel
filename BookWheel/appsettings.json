{
  "DataProtection": {
    "KeyDirectory": ""
  },
  "Security": {
    "LogRetentionDays": 14,
    "LogMaxFileSizeMb": 5,
    "UsernameLockoutThreshold": 5,
    "UsernameLockoutMinutes": 3
  },
  "Observability": {
    "EnableRequestCorrelationLogging": true,
    "EnableStartupDiagnostics": true,
    "LogShipping": {
      "Enabled": false,
      "EndpointUrl": "",
      "ApiKey": "",
      "BatchSize": 100,
      "PollIntervalSeconds": 30
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Analytics": {
    "GoogleAnalyticsId": "G-JQXW826H1F"
  }
}
